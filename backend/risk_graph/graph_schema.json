{
  "version": "1.0.0",
  "description": "Causal risk graph derived from OISD/DGMS incident taxonomies and compound failure patterns",
  "hazard_patterns": [
    {
      "id": "HP-GAS-IGNITION-HOTWORK",
      "name": "Gas Ignition During Hot Work",
      "severity": "critical",
      "description": "Elevated flammable/toxic gas concentration combined with active hot work in proximity",
      "required_conditions": [
        {"node": "COND-GAS-ELEVATED", "min_weight": 0.7},
        {"node": "COND-HOT-WORK-ACTIVE", "min_weight": 0.8},
        {"node": "COND-PROXIMITY", "min_weight": 0.6}
      ],
      "amplifying_conditions": [
        {"node": "COND-WIND-TOWARD-ZONE", "weight": 0.3},
        {"node": "COND-SHIFT-CHANGEOVER", "weight": 0.2},
        {"node": "COND-CONTRACTOR-CREW", "weight": 0.15},
        {"node": "COND-NIGHT-SHIFT-FATIGUE", "weight": 0.2}
      ],
      "historical_precedents": [
        "Vizag Steel Plant gas leak near-miss pattern",
        "Refinery hot-work ignition precursor pattern"
      ],
      "recommended_actions": [
        "Immediately suspend hot work permit in affected zone",
        "Evacuate personnel within 100m downwind radius",
        "Activate gas monitoring escalation protocol",
        "Notify emergency response team and plant safety head"
      ],
      "regulatory_references": ["OISD-GDN-117", "OISD-STD-118", "Factory Act Section 41B"]
    },
    {
      "id": "HP-H2S-EXPOSURE-CONFINED",
      "name": "H2S Exposure in Confined Space",
      "severity": "critical",
      "description": "H2S drift into confined space entry zone during active permit",
      "required_conditions": [
        {"node": "COND-H2S-DRIFT", "min_weight": 0.75},
        {"node": "COND-CONFINED-SPACE-ACTIVE", "min_weight": 0.8}
      ],
      "amplifying_conditions": [
        {"node": "COND-INADEQUATE-VENTILATION", "weight": 0.4},
        {"node": "COND-SHIFT-CHANGEOVER", "weight": 0.15}
      ],
      "historical_precedents": ["Tank farm H2S exposure incident pattern"],
      "recommended_actions": [
        "Revoke confined space entry permit",
        "Deploy additional gas monitors at entry points",
        "Verify ventilation system operation"
      ],
      "regulatory_references": ["OISD-GDN-126", "DGMS Circular on confined spaces"]
    },
    {
      "id": "HP-SIMOPS-LIFTING-GAS",
      "name": "Simultaneous Lifting Near Gas Release",
      "severity": "high",
      "description": "Heavy lifting operation concurrent with gas anomaly in overlapping zone",
      "required_conditions": [
        {"node": "COND-LIFTING-ACTIVE", "min_weight": 0.8},
        {"node": "COND-GAS-ELEVATED", "min_weight": 0.6},
        {"node": "COND-SIMOPS-OVERLAP", "min_weight": 0.7}
      ],
      "amplifying_conditions": [
        {"node": "COND-CONTRACTOR-CREW", "weight": 0.2}
      ],
      "historical_precedents": ["Crane operation during process upset"],
      "recommended_actions": [
        "Halt lifting operations until gas levels normalize",
        "Establish exclusion zone around crane swing radius"
      ],
      "regulatory_references": ["OISD-GDN-117", "Factory Act Section 22"]
    },
    {
      "id": "HP-FATIGUE-COMPLEX-PROCEDURE",
      "name": "Fatigue-Compounded Complex Operation",
      "severity": "high",
      "description": "Night shift with overtime and contractor crew executing complex permit work",
      "required_conditions": [
        {"node": "COND-NIGHT-SHIFT-FATIGUE", "min_weight": 0.7},
        {"node": "COND-CONTRACTOR-CREW", "min_weight": 0.5},
        {"node": "COND-COMPLEX-PERMIT", "min_weight": 0.6}
      ],
      "amplifying_conditions": [
        {"node": "COND-SHIFT-CHANGEOVER", "weight": 0.25}
      ],
      "historical_precedents": ["Shift handover communication failure pattern"],
      "recommended_actions": [
        "Assign experienced supervisor to oversee operation",
        "Extend pre-job safety briefing",
        "Consider deferring to day shift if non-urgent"
      ],
      "regulatory_references": ["Factory Act Section 51", "DGFASLI fatigue guidelines"]
    }
  ],
