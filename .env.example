# ARGUS Environment Configuration
# Copy this file to .env and update values as needed

# Application Settings
APP_NAME=ARGUS
APP_VERSION=1.0.0

# CORS Settings (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173

# Simulation Settings
SIMULATION_TICK_INTERVAL_SECONDS=1.0

# Sensor Settings
SENSOR_BASELINE_WINDOW=100
SENSOR_ZSCORE_THRESHOLD=2.5
SENSOR_EWMA_ALPHA=0.3
ISOLATION_FOREST_CONTAMINATION=0.1

# Trust Calibration Settings
COMPOUND_RISK_THRESHOLD=0.7

# Logging
LOG_LEVEL=INFO

# Database (if needed in future)
# DATABASE_URL=postgresql://user:password@localhost:5432/argus

# API Keys (if needed)
# ANTHROPIC_API_KEY=your_api_key_here
